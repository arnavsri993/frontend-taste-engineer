{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.frontend-taste-engineer/audits/report.schema.json",
  "title": "Frontend Taste Engineer deterministic report",
  "type": "object",
  "required": ["schema_version", "check", "passed", "summary", "errors", "warnings", "details"],
  "properties": {
    "schema_version": {"const": 1},
    "check": {"type": "string", "minLength": 1},
    "passed": {"type": "boolean"},
    "summary": {
      "type": "object",
      "required": ["errors", "warnings"],
      "properties": {
        "errors": {"type": "integer", "minimum": 0},
        "warnings": {"type": "integer", "minimum": 0}
      }
    },
    "errors": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "warnings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "details": {"type": "object"}
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "string"},
        "message": {"type": "string"},
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": true
    }
  }
}

